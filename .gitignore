*.obj
*.exe
*.pdb
*.user
*.aps
*.pch
*.dll
*.dll.*
*.vspscc
*.vssscc
*.scc
*_i.c
*_p.c
*.ncb
*.suo
*.tlb
*.tlh
*.bak
*.cache
*.ilk
*.log
[Bb]in
[Dd]ebug*/
*.lib
*.sbr
*.log
*.autosave
obj/
[Rr]elease*/

# ignore files, generated/used in linux
*.[oa]
*.so
[Mm]akefile
[Mm]akefile.*

# ignore Qt files
moc_*.*
*.pro.user
*.pro.*
ui_*.h

#ignore temporary files
*.tmp*
*~

#ignore files, generated by doxygen
doc/html
doc/html/
doc/doxy/*.log
doc/doxy/*.tag
doc/doxy/*.bat
doc/doxy/output/

#ignore files, generated by lrelease
translations/*.qm
